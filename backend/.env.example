# KWAN-TIME Backend Configuration

# Database
DATABASE_URL=postgres://kwan:kwan@localhost:5432/kwan_calendar
POSTGRES_USER=kwan
POSTGRES_PASSWORD=kwan
POSTGRES_DB=kwan_calendar
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379

# API
PORT=8080
ENV=development

# JWT (generate with: openssl genrsa -out private-key.pem 2048 && openssl rsa -in private-key.pem -pubout -out public-key.pem)
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----
MFwwDQYJKoZIhvcNAQEBBQADSwAwSAJBAL...
(replace with actual public key content)
-----END PUBLIC KEY-----

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,*

# Logging
LOG_LEVEL=info

# Feature flags
ENABLE_WEBSOCKET=true
ENABLE_NOTIFICATIONS=true
